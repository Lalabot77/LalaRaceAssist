<UserControl x:Class="LaunchPlugin.GlobalSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:local="clr-namespace:LaunchPlugin"
             xmlns:styles="clr-namespace:SimHub.Plugins.Styles;assembly=SimHub.Plugins"
             xmlns:ui="clr-namespace:SimHub.Plugins.UI;assembly=SimHub.Plugins"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="1200"
             x:Name="GlobalSettingsPage">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:HexToBrushConverter x:Key="HexToBrushConverter"/>
        <x:Array x:Key="DriverTagOptions" Type="{x:Type sys:String}">
            <sys:String>Friend</sys:String>
            <sys:String>Teammate</sys:String>
            <sys:String>Bad</sys:String>
        </x:Array>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10">

            <Expander Header="Plugin Monitor"
                      Margin="0,0,0,10"
                      IsExpanded="True">
                <StackPanel Margin="0,10,0,0">
                    <styles:SHToggleCheckbox Content="Enable Monitor System"
                                             IsChecked="{Binding Settings.MonitorSystemEnabled, Mode=TwoWay}"
                                             ToolTip="Enable the dashboard-facing MonitorSystem status and fuel-health messages." />
                </StackPanel>
            </Expander>

            <Expander Header="Dashboards"
                      Margin="0,0,0,10"
                      IsExpanded="True">
                <StackPanel Margin="0,10,0,0">
                    <styles:SHToggleCheckbox Content="Auto screen selection at session start"
                                             IsChecked="{Binding Settings.EnableAutoDashSwitch, Mode=TwoWay}"
                                             ToolTip="Automatically switch dash screens when a session starts based on context." />
                    <Grid VerticalAlignment="Center" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Dark Mode:" VerticalAlignment="Center" ToolTip="Select Dark Mode behavior: Off, Manual, or Auto."/>
                        <ComboBox Grid.Column="1" Width="85" Margin="0,0,8,0" HorizontalAlignment="Left" SelectedValue="{Binding Settings.DarkModeMode, Mode=TwoWay}" SelectedValuePath="Tag" ToolTip="0=Off (forced off), 1=Manual, 2=Auto solar dimming.">
                            <ComboBoxItem Content="Off" Tag="0" />
                            <ComboBoxItem Content="Manual" Tag="1" />
                            <ComboBoxItem Content="Auto" Tag="2" />
                        </ComboBox>
                        <styles:SHToggleCheckbox Grid.Column="2" Content="Use Lovely True Dark" VerticalAlignment="Center" IsChecked="{Binding Settings.UseLovelyTrueDark, Mode=TwoWay}" IsEnabled="{Binding IsLovelyAvailableForDarkMode}" ToolTip="When Lovely is available, Dark Mode active state can follow Lovely True Dark." />
                    </Grid>
                    <TextBlock Text="If using Lovely True Dark, bind only one toggle (Lovely OR LalaLaunch)." Margin="100,4,0,0" Opacity="0.85" TextWrapping="Wrap" />
                    <ui:TitledSlider Title="Brightness (%): " Margin="0,8,0,0" Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding Settings.DarkModeBrightnessPct, Mode=TwoWay}" ToolTip="Base Dark Mode brightness percent (0-100). 100 is brightest." />
                    <TextBlock Text="Dash Visibility" FontWeight="SemiBold" Margin="0,14,0,6"/>
                    <TextBlock Text="Choose which dash families can show each feature." Margin="0,0,0,10" Opacity="0.8" TextWrapping="Wrap" />
                    <Grid HorizontalAlignment="Left">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="220" /><ColumnDefinition Width="110" /><ColumnDefinition Width="130" /><ColumnDefinition Width="90" /></Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="DRIVER" FontWeight="Bold" Margin="0,0,0,6" HorizontalAlignment="Center" ToolTip="DRIVER = Lala Race Dash." />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="STRATEGY" FontWeight="Bold" Margin="0,0,0,6" HorizontalAlignment="Center" ToolTip="STRATEGY = Lala Strategy Dash." />
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="OVERLAY" FontWeight="Bold" Margin="0,0,0,6" HorizontalAlignment="Center" ToolTip="OVERLAY = overlay surfaces." />
                        <TextBlock Text="Standing Start Assist" Grid.Row="1" Grid.Column="0" Margin="0,5,12,0" VerticalAlignment="Center" />
                        <styles:SHToggleCheckbox Grid.Row="1" Grid.Column="1" Content="" Margin="0,5,0,0" HorizontalAlignment="Center" IsChecked="{Binding Settings.LalaDashShowLaunchScreen, Mode=TwoWay}" />
                        <styles:SHToggleCheckbox Grid.Row="1" Grid.Column="2" Content="" Margin="0,5,0,0" HorizontalAlignment="Center" IsChecked="{Binding Settings.MsgDashShowLaunchScreen, Mode=TwoWay}" />
                        <styles:SHToggleCheckbox Grid.Row="1" Grid.Column="3" Content="" Margin="0,5,0,0" HorizontalAlignment="Center" IsChecked="{Binding Settings.OverlayDashShowLaunchScreen, Mode=TwoWay}" />
                        <TextBlock Text="Pit Entry Assist" Grid.Row="2" Grid.Column="0" Margin="0,5,12,0" VerticalAlignment="Center" />
                        <styles:SHToggleCheckbox Grid.Row="2" Grid.Column="1" Content="" Margin="0,5,0,0" HorizontalAlignment="Center" IsChecked="{Binding Settings.LalaDashShowPitEntryAssist, Mode=TwoWay}" />
                        <styles:SHToggleCheckbox Grid.Row="2" Grid.Column="2" Content="" Margin="0,5,0,0" HorizontalAlignment="Center" IsChecked="{Binding Settings.MsgDashShowPitEntryAssist, Mode=TwoWay}" />
                        <styles:SHToggleCheckbox Grid.Row="2" Grid.Column="3" Content="" Margin="0,5,0,0" HorizontalAlignment="Center" IsChecked="{Binding Settings.OverlayDashShowPitEntryAssist, Mode=TwoWay}" />
                        <TextBlock Text="Pit Box Assist" Grid.Row="3" Grid.Column="0" Margin="0,5,12,0" VerticalAlignment="Center" />
                        <styles:SHToggleCheckbox Grid.Row="3" Grid.Column="1" Content="" Margin="0,5,0,0" HorizontalAlignment="Center" IsChecked="{Binding Settings.LalaDashShowPitBoxAssist, Mode=TwoWay}" />
                        <styles:SHToggleCheckbox Grid.Row="3" Grid.Column="2" Content="" Margin="0,5,0,0" HorizontalAlignment="Center" IsChecked="{Binding Settings.MsgDashShowPitBoxAssist, Mode=TwoWay}" />
                        <styles:SHToggleCheckbox Grid.Row="3" Grid.Column="3" Content="" Margin="0,5,0,0" HorizontalAlignment="Center" IsChecked="{Binding Settings.OverlayDashShowPitBoxAssist, Mode=TwoWay}" />
                        <TextBlock Text="Pit Limiter" Grid.Row="4" Grid.Column="0" Margin="0,5,12,0" VerticalAlignment="Center" />
                        <styles:SHToggleCheckbox Grid.Row="4" Grid.Column="1" Content="" Margin="0,5,0,0" HorizontalAlignment="Center" IsChecked="{Binding Settings.LalaDashShowPitLimiter, Mode=TwoWay}" />
                        <styles:SHToggleCheckbox Grid.Row="4" Grid.Column="2" Content="" Margin="0,5,0,0" HorizontalAlignment="Center" IsChecked="{Binding Settings.MsgDashShowPitLimiter, Mode=TwoWay}" />
                        <styles:SHToggleCheckbox Grid.Row="4" Grid.Column="3" Content="" Margin="0,5,0,0" HorizontalAlignment="Center" IsChecked="{Binding Settings.OverlayDashShowPitLimiter, Mode=TwoWay}" />
                        <TextBlock Text="Show Automatic Pit Screen" Grid.Row="5" Grid.Column="0" Margin="0,5,12,0" VerticalAlignment="Center" />
                        <styles:SHToggleCheckbox Grid.Row="5" Grid.Column="1" Content="" Margin="0,5,0,0" HorizontalAlignment="Center" IsChecked="{Binding Settings.LalaDashShowPitScreen, Mode=TwoWay}" />
                        <styles:SHToggleCheckbox Grid.Row="5" Grid.Column="2" Content="" Margin="0,5,0,0" HorizontalAlignment="Center" IsChecked="{Binding Settings.MsgDashShowPitScreen, Mode=TwoWay}" />
                        <styles:SHToggleCheckbox Grid.Row="5" Grid.Column="3" Content="" Margin="0,5,0,0" HorizontalAlignment="Center" IsChecked="{Binding Settings.OverlayDashShowPitScreen, Mode=TwoWay}" />
                        <TextBlock Text="Rejoin Assist" Grid.Row="6" Grid.Column="0" Margin="0,5,12,0" VerticalAlignment="Center" />
                        <styles:SHToggleCheckbox Grid.Row="6" Grid.Column="1" Content="" Margin="0,5,0,0" HorizontalAlignment="Center" IsChecked="{Binding Settings.LalaDashShowRejoinAssist, Mode=TwoWay}" />
                        <styles:SHToggleCheckbox Grid.Row="6" Grid.Column="2" Content="" Margin="0,5,0,0" HorizontalAlignment="Center" IsChecked="{Binding Settings.MsgDashShowRejoinAssist, Mode=TwoWay}" />
                        <styles:SHToggleCheckbox Grid.Row="6" Grid.Column="3" Content="" Margin="0,5,0,0" HorizontalAlignment="Center" IsChecked="{Binding Settings.OverlayDashShowRejoinAssist, Mode=TwoWay}" />
                        <TextBlock Text="Verbose Race Messages" Grid.Row="7" Grid.Column="0" Margin="0,5,12,0" VerticalAlignment="Center" />
                        <styles:SHToggleCheckbox Grid.Row="7" Grid.Column="1" Content="" Margin="0,5,0,0" HorizontalAlignment="Center" IsChecked="{Binding Settings.LalaDashShowVerboseMessaging, Mode=TwoWay}" />
                        <styles:SHToggleCheckbox Grid.Row="7" Grid.Column="2" Content="" Margin="0,5,0,0" HorizontalAlignment="Center" IsChecked="{Binding Settings.MsgDashShowVerboseMessaging, Mode=TwoWay}" />
                        <styles:SHToggleCheckbox Grid.Row="7" Grid.Column="3" Content="" Margin="0,5,0,0" HorizontalAlignment="Center" IsChecked="{Binding Settings.OverlayDashShowVerboseMessaging, Mode=TwoWay}" />
                        <TextBlock Text="Race Flags" Grid.Row="8" Grid.Column="0" Margin="0,5,12,0" VerticalAlignment="Center" />
                        <styles:SHToggleCheckbox Grid.Row="8" Grid.Column="1" Content="" Margin="0,5,0,0" HorizontalAlignment="Center" IsChecked="{Binding Settings.LalaDashShowRaceFlags, Mode=TwoWay}" />
                        <styles:SHToggleCheckbox Grid.Row="8" Grid.Column="2" Content="" Margin="0,5,0,0" HorizontalAlignment="Center" IsChecked="{Binding Settings.MsgDashShowRaceFlags, Mode=TwoWay}" />
                        <styles:SHToggleCheckbox Grid.Row="8" Grid.Column="3" Content="" Margin="0,5,0,0" HorizontalAlignment="Center" IsChecked="{Binding Settings.OverlayDashShowRaceFlags, Mode=TwoWay}" />
                        <TextBlock Text="Radio Messages" Grid.Row="9" Grid.Column="0" Margin="0,5,12,0" VerticalAlignment="Center" />
                        <styles:SHToggleCheckbox Grid.Row="9" Grid.Column="1" Content="" Margin="0,5,0,0" HorizontalAlignment="Center" IsChecked="{Binding Settings.LalaDashShowRadioMessages, Mode=TwoWay}" />
                        <styles:SHToggleCheckbox Grid.Row="9" Grid.Column="2" Content="" Margin="0,5,0,0" HorizontalAlignment="Center" IsChecked="{Binding Settings.MsgDashShowRadioMessages, Mode=TwoWay}" />
                        <styles:SHToggleCheckbox Grid.Row="9" Grid.Column="3" Content="" Margin="0,5,0,0" HorizontalAlignment="Center" IsChecked="{Binding Settings.OverlayDashShowRadioMessages, Mode=TwoWay}" />
                        <TextBlock Text="Show Traffic Alerts" Grid.Row="10" Grid.Column="0" Margin="0,5,12,0" VerticalAlignment="Center" />
                        <styles:SHToggleCheckbox Grid.Row="10" Grid.Column="1" Content="" Margin="0,5,0,0" HorizontalAlignment="Center" IsChecked="{Binding Settings.LalaDashShowTraffic, Mode=TwoWay}" />
                        <styles:SHToggleCheckbox Grid.Row="10" Grid.Column="2" Content="" Margin="0,5,0,0" HorizontalAlignment="Center" IsChecked="{Binding Settings.MsgDashShowTraffic, Mode=TwoWay}" />
                        <styles:SHToggleCheckbox Grid.Row="10" Grid.Column="3" Content="" Margin="0,5,0,0" HorizontalAlignment="Center" IsChecked="{Binding Settings.OverlayDashShowTraffic, Mode=TwoWay}" />
                    </Grid>
                </StackPanel>
            </Expander>

            <Expander Header="{Binding LeagueRaceSettingsHeaderText}"
                      Margin="0,0,0,10"
                      IsExpanded="False">
                <StackPanel Margin="0,10,0,0">
                    <TextBlock Text="League Classes"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <styles:SHToggleCheckbox Content="Enable League Class System"
                                             IsChecked="{Binding Settings.LeagueClassEnabled, Mode=TwoWay}"/>
                    <TextBlock Margin="0,4,0,0" Foreground="LightGray" Text="League Class system disabled">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Settings.LeagueClassEnabled}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>


                    <StackPanel Margin="0,6,0,0" Visibility="{Binding Settings.LeagueClassEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Classification mode" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Width="320"
                                  SelectedValue="{Binding Settings.LeagueClassMode, Mode=TwoWay}"
                                  SelectedValuePath="Tag">
                            <ComboBoxItem Content="CSV only" Tag="1"/>
                            <ComboBoxItem Content="Name suffix only" Tag="2"/>
                            <ComboBoxItem Content="CSV, then name suffix" Tag="3"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="CSV file" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="LeagueClassCsvPathTextBox" Width="420" Text="{Binding Settings.LeagueClassCsvPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <styles:SHButtonPrimary Content="Browse" Margin="8,0,0,0" Click="BrowseLeagueClassCsv_Click"/>
                        <styles:SHButtonPrimary Content="Reload" Margin="8,0,0,0" Click="ReloadLeagueClassCsv_Click"/>
                    </StackPanel>
                    <StackPanel Visibility="{Binding LeagueClassShowCsvSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Margin="0,6,0,0" Foreground="{Binding LeagueClassHelperForeground}" Text="{Binding LeagueClassCsvStatusSummaryText}"/>
                        <TextBlock Margin="0,8,0,2" Text="Detected classes" FontWeight="SemiBold"/>
                        <Grid Margin="0,0,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="18"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="CSV Class Name" ToolTip="Class name read from CSV"/>
                            <TextBlock Grid.Column="4" FontWeight="SemiBold" Text="Short Name" ToolTip="Dash/display label"/>
                            <TextBlock Grid.Column="6" FontWeight="SemiBold" Text="Rank" ToolTip="1 = fastest/highest class"/>
                            <TextBlock Grid.Column="8" FontWeight="SemiBold" Text="Colour Hex" ToolTip="Dash colour, #RRGGBB"/>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding Settings.LeagueClassDefinitions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="18"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="18"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding Enabled, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="2" Width="130" Text="{Binding CsvClassName}" IsReadOnly="True" ToolTip="Class name read from CSV"/>
                                        <TextBox Grid.Column="4" Width="100" Text="{Binding ShortName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="Dash/display label"/>
                                        <TextBox Grid.Column="6" Width="50" Text="{Binding Rank, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="1 = fastest/highest class"/>
                                        <TextBox Grid.Column="8" Width="90" Text="{Binding ColourHex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="Dash colour, #RRGGBB"/>
                                        <Border Grid.Column="10" Width="18" Height="18" Margin="0,2,0,0" BorderBrush="#777" BorderThickness="1" Background="{Binding ColourHex, Converter={StaticResource HexToBrushConverter}}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <TextBlock Margin="0,8,0,2" Text="Player race class" FontWeight="SemiBold"/>
                    <Grid Margin="0,0,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="18"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="Class Name"/>
                        <TextBlock Grid.Column="4" FontWeight="SemiBold" Text="Short Name"/>
                        <TextBlock Grid.Column="6" FontWeight="SemiBold" Text="Rank"/>
                        <TextBlock Grid.Column="8" FontWeight="SemiBold" Text="Colour Hex"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="18"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" Width="180" SelectedValue="{Binding Settings.LeagueClassPlayerOverrideMode, Mode=TwoWay}" SelectedValuePath="Tag">
                            <ComboBoxItem Content="Auto-detect" Tag="0"/>
                            <ComboBoxItem Content="Manual override" Tag="1"/>
                        </ComboBox>
                        <TextBox Grid.Column="2" Width="120" Text="{Binding LeagueClassPlayerClassNameEditorText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="Class name" IsReadOnly="{Binding LeagueClassPlayerOverrideIsAutoDetect}"/>
                        <TextBox Grid.Column="4" Width="90" Text="{Binding LeagueClassPlayerShortNameEditorText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="Short" IsReadOnly="{Binding LeagueClassPlayerOverrideIsAutoDetect}"/>
                        <TextBox Grid.Column="6" Width="50" Text="{Binding LeagueClassPlayerRankEditorText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="Rank" IsReadOnly="{Binding LeagueClassPlayerOverrideIsAutoDetect}"/>
                        <TextBox x:Name="LeagueClassPlayerOverrideColourHexTextBox" Grid.Column="8" Width="90" Text="{Binding LeagueClassPlayerColourHexEditorText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="#RRGGBB" IsReadOnly="{Binding LeagueClassPlayerOverrideIsAutoDetect}"/>
                        <Border Grid.Column="10" Width="18" Height="18" Margin="0,2,0,0" BorderBrush="#777" BorderThickness="1" Background="{Binding LeagueClassPlayerColourHexEditorText, Converter={StaticResource HexToBrushConverter}}"/>
                    </Grid>
                    <TextBlock Margin="0,6,0,0" Foreground="{Binding LeagueClassHelperForeground}" Text="{Binding LeagueClassPlayerPreviewText}"/>

                    <TextBlock Margin="0,8,0,2" Text="Fallback rules (suffix)" FontWeight="SemiBold" Visibility="{Binding LeagueClassShowFallbackSection, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Grid Margin="0,0,0,2" Visibility="{Binding LeagueClassShowFallbackSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="18"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="Match Suffix" ToolTip="Name ending to match, e.g. (P)"/>
                        <TextBlock Grid.Column="4" FontWeight="SemiBold" Text="Class Name"/>
                        <TextBlock Grid.Column="6" FontWeight="SemiBold" Text="Short Name" ToolTip="Dash/display label"/>
                        <TextBlock Grid.Column="8" FontWeight="SemiBold" Text="Rank" ToolTip="1 = fastest/highest class"/>
                        <TextBlock Grid.Column="10" FontWeight="SemiBold" Text="Colour Hex" ToolTip="Dash colour, #RRGGBB"/>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding Settings.LeagueClassFallbackRules}" Visibility="{Binding LeagueClassShowFallbackSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2,0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="18"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="{Binding Enabled, Mode=TwoWay}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="2" Width="90" Text="{Binding MatchSuffix, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="Name ending to match, e.g. (P)"/>
                                    <TextBox Grid.Column="4" Width="120" Text="{Binding ClassName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="Class name"/>
                                    <TextBox Grid.Column="6" Width="90" Text="{Binding ShortName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="Dash/display label"/>
                                    <TextBox Grid.Column="8" Width="50" Text="{Binding Rank, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="1 = fastest/highest class"/>
                                    <TextBox Grid.Column="10" Width="90" Text="{Binding ColourHex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="Dash colour, #RRGGBB"/>
                                    <Border Grid.Column="12" Width="18" Height="18" Margin="0,2,0,0" BorderBrush="#777" BorderThickness="1" Background="{Binding ColourHex, Converter={StaticResource HexToBrushConverter}}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </Expander>

            <Expander Header="Fuel Strategy"
                      Margin="0,0,0,10"
                      IsExpanded="False">
                <StackPanel Margin="0,10,0,0">
                    <ui:TitledSlider Title="Fuel Ready Confidence: " Minimum="0" Maximum="100" Value="{Binding Settings.FuelReadyConfidence, Mode=TwoWay}" ToolTip="Minimum confidence (%) before pit strategy uses live fuel. Below this, profile estimates may be used." />
                    <TextBlock Text="Below 20%, profile fuel may be used for early estimates. Above 20%, pit strategy waits for live fuel data." FontSize="11" Opacity="0.7" TextWrapping="Wrap" Margin="0,2,0,0"/>
                    <ui:TitledSlider Title="Pit-in Fuel Reserve (% lap): " Margin="0,8,0,0" Minimum="0" Maximum="30" Value="{Binding Settings.StintFuelMarginPct, Mode=TwoWay}" ToolTip="Reserve fuel as a percentage of one lap (based on stable fuel burn) when calculating stint burn targets." />
                    <styles:SHToggleCheckbox Content="Fuel Data Plan Mode" Margin="0,8,0,0" IsChecked="{Binding Settings.PitFuelControlDataPlanModeEnabled, Mode=TwoWay}" ToolTip="Toggle Pit Fuel Control DATA. OFF = LIVE runtime burn assumptions, ON = PLAN memory/profile assumptions for PUSH/SAVE. Changing DATA parks SOURCE at STBY." />
                    <TextBlock Text="OFF = LIVE, ON = PLAN" FontSize="11" Opacity="0.7" TextWrapping="Wrap" Margin="0,2,0,0"/>
                    <ui:TitledSlider Title="DATA PLAN Push/Save Guard (%): " Margin="0,8,0,0" Minimum="0" Maximum="30" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding Settings.PitFuelPushSaveProfileGuardPct, Mode=TwoWay}" ToolTip="When DATA is PLAN, caps memory/profile push/save burn around live stable NORM burn by this guard percentage." />
                    <styles:SHToggleCheckbox Content="Pit.Box: include optional repairs in service countdown" Margin="0,8,0,10" IsChecked="{Binding Settings.PitBoxIncludeOptionalRepairs, Mode=TwoWay}" ToolTip="When enabled, optional repair time is included in Pit.Box target/remaining countdown and shared total-stop-loss prediction. Mandatory repair time is always included when native authority is valid while boxed."/>
                </StackPanel>
            </Expander>
            <Expander Header="Friends List"
                      Margin="0,0,0,10"
                      IsExpanded="False">
                <StackPanel Margin="0,10,0,0">
                    <TextBlock Margin="0,0,0,5" Foreground="LightGray"
                               Text="Add iRacing Customer IDs and assign a driver tag in CarSA." />
                    <StackPanel Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Import iOverlay"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <ComboBox x:Name="IOverlayCategoryComboBox"
                                      Grid.Column="1"
                                      MinWidth="220"
                                      Margin="0,0,8,0" />
                            <ComboBox x:Name="IOverlayTagComboBox"
                                      Grid.Column="2"
                                      MinWidth="130"
                                      Margin="0,0,8,0"
                                      ItemsSource="{StaticResource DriverTagOptions}"
                                      SelectedIndex="0" />
                            <styles:SHButtonPrimary Grid.Column="3"
                                                    Content="Import"
                                                    Padding="8,2"
                                                    MinWidth="70"
                                                    Click="ImportIOverlay_Click" />
                            <styles:SHButtonPrimary Grid.Column="4"
                                                    Content="Reload"
                                                    Padding="8,2"
                                                    MinWidth="70"
                                                    Click="ReloadIOverlay_Click" />
                        </Grid>
                        <TextBlock x:Name="IOverlayStatusText"
                                   Margin="0,4,0,0"
                                   Foreground="LightGray" />
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding Settings.Friends}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              RowEditEnding="FriendsGrid_RowEditEnding"
                              Margin="0,0,0,8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="NAME"
                                                Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Width="*" />
                            <DataGridTextColumn Header="UserId"
                                                Binding="{Binding UserId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Width="120" />
                            <DataGridComboBoxColumn Header="TAG"
                                                    SelectedItemBinding="{Binding Tag, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    ItemsSource="{StaticResource DriverTagOptions}"
                                                    Width="120" />
                            <DataGridTemplateColumn Header="REMOVE" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <styles:SHButtonPrimary Content="Remove"
                                                                Padding="8,2"
                                                                Margin="0"
                                                                MinWidth="70"
                                                                Background="#C62828"
                                                                Foreground="White"
                                                                Click="RemoveFriend_Click" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <styles:SHButtonPrimary Content="Add Driver"
                                            Width="120"
                                            HorizontalAlignment="Left"
                                            Click="AddFriend_Click" />
                </StackPanel>
            </Expander>




            <Expander Header="Debug"
                      Margin="0,0,0,10"
                      IsExpanded="False"
                      Visibility="{Binding HardDebugEnabledForUi, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Margin="0,10,0,0">
                <styles:SHToggleCheckbox x:Name="DebugMasterToggle"
                                         Content="Enable debugging mode"
                                         Margin="0,10,0,0"
                                         Click="DebugMasterToggle_Click"
                                         IsChecked="{Binding Settings.EnableSoftDebug, Mode=TwoWay}"
                                         ToolTip="Master toggle that enables debug UI and debug processing."/>
                <TextBlock Margin="0,6,0,0"
                           Foreground="LightGray"
                           Opacity="0.9"
                           TextWrapping="Wrap"
                           Text="Debug mode is for troubleshooting only. Leave this off unless asked to enable it."/>
                <Expander Header="Debug Options"
                          Margin="0,10,0,0"
                          IsExpanded="{Binding ElementName=DebugMasterToggle, Path=IsChecked}"
                          Visibility="{Binding ElementName=DebugMasterToggle, Path=IsChecked, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Margin="10,5,0,0">
                        <TextBlock Text="General logging" FontWeight="SemiBold" Margin="0,10,0,4"/>
                        <Separator Margin="0,0,0,6"/>
                        <styles:SHToggleCheckbox Content="Enable Debug Logging"
                                                 IsChecked="{Binding Settings.EnableDebugLogging, Mode=TwoWay}"
                                                 ToolTip="Enables extra troubleshooting/detail logs only while master debugging mode is also enabled."/>
                        <styles:SHToggleCheckbox Content="Enable Monitor Event CSV" Margin="0,10,0,0"
                                                 IsChecked="{Binding Settings.EnableMonitorEventCsv, Mode=TwoWay}"
                                                 ToolTip="Writes non-normal MonitorSystem event rows to SimHub\Logs\LalaPluginData\MonitorSystem_Events.csv for troubleshooting."/>
                        <StackPanel Orientation="Vertical" Margin="0,10,0,0">
                            <styles:SHToggleCheckbox x:Name="PropertySnapshotToggle"
                                                     Content="Enable Property Snapshot"
                                                     Click="PropertySnapshotRollingStatusRefresh_Click"
                                                     IsChecked="{Binding Settings.EnablePropertySnapshot, Mode=TwoWay}"
                                                     ToolTip="When enabled, pressing Event Marker writes a CSV snapshot of plugin properties."/>
                            <StackPanel Margin="22,6,0,0"
                                        Visibility="{Binding ElementName=PropertySnapshotToggle, Path=IsChecked, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <WrapPanel>
                                    <CheckBox x:Name="PropertySnapshotSelectAllCheckBox"
                                              Content="Select All"
                                              Margin="0,0,12,6"
                                              Click="PropertySnapshotSelectAll_Click"
                                              IsChecked="{Binding Settings.PropertySnapshotSelectAllGroups, Mode=TwoWay}"/>
                                    <CheckBox x:Name="PropertySnapshotFuelStrategyCheckBox" Content="Fuel/Strategy" Margin="0,0,12,6" Click="PropertySnapshotGroup_Click" IsChecked="{Binding Settings.PropertySnapshotGroupFuelStrategy, Mode=TwoWay}"/>
                                    <CheckBox x:Name="PropertySnapshotCarOppH2HCheckBox" Content="Car/Opp/H2H" Margin="0,0,12,6" Click="PropertySnapshotGroup_Click" IsChecked="{Binding Settings.PropertySnapshotGroupCarOppH2H, Mode=TwoWay}"/>
                                    <CheckBox x:Name="PropertySnapshotPitPitExitCheckBox" Content="Pit/PitExit" Margin="0,0,12,6" Click="PropertySnapshotGroup_Click" IsChecked="{Binding Settings.PropertySnapshotGroupPitPitExit, Mode=TwoWay}"/>
                                    <CheckBox x:Name="PropertySnapshotShiftAssistCheckBox" Content="Shift Assist" Margin="0,0,12,6" Click="PropertySnapshotGroup_Click" IsChecked="{Binding Settings.PropertySnapshotGroupShiftAssist, Mode=TwoWay}"/>
                                    <CheckBox x:Name="PropertySnapshotMessageSystemCheckBox" Content="Message System" Margin="0,0,12,6" Click="PropertySnapshotGroup_Click" IsChecked="{Binding Settings.PropertySnapshotGroupMessageSystem, Mode=TwoWay}"/>
                                    <CheckBox x:Name="PropertySnapshotLeagueClassCheckBox" Content="League Class" Margin="0,0,12,6" Click="PropertySnapshotGroup_Click" IsChecked="{Binding Settings.PropertySnapshotGroupLeagueClass, Mode=TwoWay}"/>
                                    <CheckBox x:Name="PropertySnapshotRawDebugCheckBox" Content="Raw Debug" Margin="0,0,12,6" Click="PropertySnapshotGroup_Click" IsChecked="{Binding Settings.PropertySnapshotGroupRawDebug, Mode=TwoWay}"/>
                                </WrapPanel>
                                <WrapPanel Margin="0,0,0,2">
                                    <CheckBox Content="Include changed vs previous" Margin="0,0,12,6" IsChecked="{Binding Settings.PropertySnapshotIncludeChangedValues, Mode=TwoWay}"/>
                                    <CheckBox x:Name="PropertySnapshotRollingCombinedCsvCheckBox" Content="Write rolling combined CSV" Margin="0,0,12,6" Click="PropertySnapshotRollingStatusRefresh_Click" IsChecked="{Binding Settings.PropertySnapshotRollingCombinedCsv, Mode=TwoWay}"/>
                                </WrapPanel>
                                <StackPanel Margin="0,2,0,0"
                                            Visibility="{Binding ElementName=PropertySnapshotRollingCombinedCsvCheckBox, Path=IsChecked, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <WrapPanel>
                                        <TextBlock Text="Rolling mode" VerticalAlignment="Center" Margin="0,0,8,6"/>
                                        <ComboBox x:Name="PropertySnapshotRollingModeComboBox" Width="170" Margin="0,0,12,6" SelectionChanged="PropertySnapshotRollingStatusRefresh_Click" SelectedIndex="{Binding Settings.PropertySnapshotRollingMode, Mode=TwoWay}">
                                            <ComboBoxItem Content="MANUAL"/>
                                            <ComboBoxItem Content="FREQUENCY"/>
                                            <ComboBoxItem Content="PER LAP"/>
                                        </ComboBox>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ElementName=PropertySnapshotRollingModeComboBox, Path=SelectedIndex}" Value="1">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Text="Frequency Hz" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBox x:Name="PropertySnapshotRollingFrequencyTextBox" Width="60" LostFocus="PropertySnapshotRollingFrequencyTextBox_LostFocus" Text="{Binding Settings.PropertySnapshotRollingFrequencyHz, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="Used in FREQUENCY mode. Valid range 1 to 2 Hz; higher entries are normalized to 2."/>
                                        </StackPanel>
                                        <Button x:Name="PropertySnapshotStartRollingButton" Content="START" Margin="0,0,8,6" Padding="10,2" Click="PropertySnapshotStartRolling_Click"/>
                                        <Button x:Name="PropertySnapshotStopRollingButton" Content="STOP" Margin="0,0,8,6" Padding="10,2" Click="PropertySnapshotStopRolling_Click"/>
                                        <Button x:Name="PropertySnapshotResetRollingCsvButton" Content="RESET ROLLING CSV" Margin="0,0,12,6" Padding="10,2" Click="PropertySnapshotResetRollingCsv_Click"/>
                                    </WrapPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                                        <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" Foreground="LightGray" Text="ROLLING CSV:"/>
                                        <Border x:Name="PropertySnapshotRollingStatusBorder" Padding="8,1" CornerRadius="10" BorderThickness="1" Background="#222222" BorderBrush="#666666">
                                            <TextBlock x:Name="PropertySnapshotRollingStatusTextBlock" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#D8D8D8" Text="OFF"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Margin="0,2,0,0" Foreground="LightGray" TextWrapping="Wrap" Text="MANUAL: Event Marker writes one snapshot. FREQUENCY: START/STOP captures rolling snapshots at 1–2 snapshots/sec. PER LAP: START/STOP captures one rolling snapshot per completed lap."/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="CarSA diagnostics" FontWeight="SemiBold" Margin="0,16,0,4"/>
                        <Separator Margin="0,0,0,6"/>
                        <styles:SHToggleCheckbox x:Name="CarSADebugCsvToggle" Content="CarSA Debug CSV"
                                                 IsChecked="{Binding Settings.EnableCarSADebugExport, Mode=TwoWay}"
                                                 ToolTip="Writes CarSA debug CSV logs to SimHub\Logs\LalapluginData while master debugging mode is enabled."/>
                        <StackPanel Margin="22,6,0,0" Visibility="{Binding ElementName=CarSADebugCsvToggle, Path=IsChecked, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <WrapPanel>
                                <TextBlock Text="Cadence" VerticalAlignment="Center" Margin="0,0,8,6"/>
                                <ComboBox x:Name="CarSADebugCadenceComboBox" Width="220" Margin="0,0,12,6" SelectedIndex="{Binding Settings.CarSADebugExportCadence, Mode=TwoWay}">
                                    <ComboBoxItem Content="Tick" />
                                    <ComboBoxItem Content="MiniSector" />
                                    <ComboBoxItem Content="Event changes only" />
                                </ComboBox>
                                <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ElementName=CarSADebugCadenceComboBox, Path=SelectedIndex}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="Tick mode max Hz" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox Width="80" Text="{Binding Settings.CarSADebugExportTickMaxHz, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <styles:SHToggleCheckbox Content="Write CarSA events CSV" Margin="0,0,0,6" IsChecked="{Binding Settings.CarSADebugExportWriteEventsCsv, Mode=TwoWay}"/>
                            </WrapPanel>
                        </StackPanel>

                        <TextBlock Text="Car Tracking Probe CSV" FontWeight="SemiBold" Margin="0,16,0,4"/>
                        <Separator Margin="0,0,0,6"/>
                        <styles:SHToggleCheckbox x:Name="CarTrackingProbeCsvToggle" Content="Enable Car Tracking Probe" IsChecked="{Binding Settings.EnableCarTrackingProbeCsv, Mode=TwoWay}" Click="CarTrackingProbeCsvToggle_Click" ToolTip="Enable targeted diagnostic CSV capture for player plus Probe A/B CarIdx values."/>
                        <StackPanel Margin="22,6,0,0" Visibility="{Binding ElementName=CarTrackingProbeCsvToggle, Path=IsChecked, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <WrapPanel>
                                <TextBlock Text="Probe A CarIdx" VerticalAlignment="Center" Margin="0,0,8,6"/>
                                <TextBox Width="70" Margin="0,0,12,6" Text="{Binding Settings.CarTrackingProbeACarIdx, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Text="Probe B CarIdx" VerticalAlignment="Center" Margin="0,0,8,6"/>
                                <TextBox Width="70" Margin="0,0,12,6" Text="{Binding Settings.CarTrackingProbeBCarIdx, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Text="Frequency Hz" VerticalAlignment="Center" Margin="0,0,8,6"/>
                                <TextBox Width="60" Margin="0,0,12,6" Text="{Binding Settings.CarTrackingProbeCsvFrequencyHz, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="Allowed range: 1 to 20 Hz."/>
                                <Button x:Name="CarTrackingProbeStartButton" Content="START" Margin="0,0,8,6" Padding="10,2" Click="CarTrackingProbeStart_Click"/>
                                <Button x:Name="CarTrackingProbeStopButton" Content="STOP" Margin="0,0,8,6" Padding="10,2" Click="CarTrackingProbeStop_Click"/>
                                <Button x:Name="CarTrackingProbeResetCsvButton" Content="RESET CSV" Margin="0,0,12,6" Padding="10,2" Click="CarTrackingProbeResetCsv_Click"/>
                            </WrapPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" Foreground="LightGray" Text="PROBE CSV:"/>
                                <Border x:Name="CarTrackingProbeCsvStatusBorder" Padding="8,1" CornerRadius="10" BorderThickness="1" Background="#222222" BorderBrush="#666666">
                                    <TextBlock x:Name="CarTrackingProbeCsvStatusTextBlock" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#D8D8D8" Text="OFF"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Foreground="LightGray" TextWrapping="Wrap" Text="Writes player + Probe A/B raw CarIdx telemetry and CarSA/Opp/H2H correlation fields for diagnostics only."/>
                        </StackPanel>

                        <TextBlock Text="Shift Assist diagnostics" FontWeight="SemiBold" Margin="0,16,0,4"/>
                        <Separator Margin="0,0,0,6"/>
                        <styles:SHToggleCheckbox Content="Mute Shift Assist sound in replay" IsChecked="{Binding Settings.ShiftAssistMuteInReplay, Mode=TwoWay}" ToolTip="Suppress Shift Assist sound during replay sessions. Shift lights, learning, and other Shift Assist logic continue to run normally."/>
                        <styles:SHToggleCheckbox x:Name="ShiftAssistDebugCsvToggle" Content="Shift Assist Debug CSV" Margin="0,8,0,0" IsChecked="{Binding Settings.EnableShiftAssistDebugCsv, Mode=TwoWay}" ToolTip="Writes a diagnostic CSV for Shift Assist triggering and suppression analysis while master debugging mode is enabled."/>
                        <StackPanel Orientation="Horizontal" Margin="22,6,0,0" Visibility="{Binding ElementName=ShiftAssistDebugCsvToggle, Path=IsChecked, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Shift Assist Debug Max Hz" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox Width="80" Text="{Binding Settings.ShiftAssistDebugCsvMaxHz, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="Allowed range: 1 to 60 Hz."/>
                        </StackPanel>

                        <TextBlock Text="Debug Actions" FontWeight="SemiBold" Margin="0,16,0,4"/>
                        <Separator Margin="0,0,0,6"/>
                        <ui:ControlsEditor ActionName="LalaLaunch.EventMarker" FriendlyName="Event Marker" ToolTip="Assign a button to fire a short event marker pulse for dashboards and CSV exports."/>
                    </StackPanel>
                </Expander>
                </StackPanel>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</UserControl>
